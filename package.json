{
  "name": "gpt-app-template",
  "version": "0.0.1",
  "description": "Template for building ChatGPT GPT Apps with MCP, React widgets, and Storybook",
  "main": "index.js",
  "type": "module",
  "bin": {
    "gpt-app-template": "./build/server/src/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "tscheck": "tsc --project tsconfig.check.json",
    "pretest": "npm run tscheck",
    "verify": "npm run tscheck && npm run test && npm run build",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build web",
    "build:server": "tsc && chmod 755 build/server/src/index.js",
    "debug": "npx @modelcontextprotocol/inspector --config inspector-config.json --server gpt-app-template",
    "storybook": "storybook dev -p 6006 --config-dir web/.storybook",
    "storybook:build": "storybook build --config-dir web/.storybook --output-dir web/storybook-static"
  },
  "keywords": [
    "chatgpt",
    "gpt-app",
    "mcp",
    "template",
    "openai",
    "widgets"
  ],
  "author": "jaksm",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@openai/apps-sdk-ui": "^0.2.1",
    "@storybook/addon-a11y": "^10.1.8",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-onboarding": "^10.1.8",
    "@storybook/addon-themes": "^10.1.8",
    "@storybook/addon-vitest": "^10.1.8",
    "@storybook/react": "^10.1.8",
    "@storybook/react-vite": "^10.1.8",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "happy-dom": "^20.8.8",
    "playwright": "^1.57.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "storybook": "^10.1.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
